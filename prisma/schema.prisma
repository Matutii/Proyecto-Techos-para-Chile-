// Techos Para Chile — Schema Prisma
// Base de datos: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USUARIOS Y ROLES
// ============================================================

model Usuario {
  id         Int      @id @default(autoincrement())
  nombre     String   @db.VarChar(100)
  email      String   @unique @db.VarChar(150)
  passwordHash String  @map("password_hash") @db.VarChar(255)
  rol        Rol
  activo     Boolean  @default(true)
  creadoEn   DateTime @default(now()) @map("creado_en")

  // Relaciones
  historialStock HistorialStock[]
  donaciones     Donacion[]

  @@map("usuarios")
}

enum Rol {
  admin
  colaborador
  coordinador_logistica
}

// ============================================================
// PROYECTOS
// ============================================================

model Proyecto {
  id          Int      @id @default(autoincrement())
  nombre      String   @db.VarChar(200)
  descripcion String?  @db.Text
  estado      String   @default("activo") @db.VarChar(50)
  creadoEn    DateTime @default(now()) @map("creado_en")

  // Relaciones
  materiales Material[]

  @@map("proyectos")
}

// ============================================================
// R1 — STOCK / MATERIALES
// ============================================================

model Material {
  id           Int           @id @default(autoincrement())
  nombre       String        @db.VarChar(200)
  descripcion  String?       @db.Text
  estado       EstadoMaterial @default(Disponible)
  proyectoId   Int?          @map("proyecto_id")
  actualizadoEn DateTime     @default(now()) @map("actualizado_en")

  // Relaciones
  proyecto       Proyecto?        @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
  historialStock HistorialStock[]

  @@map("materiales")
}

enum EstadoMaterial {
  Disponible
  Agotado
  En_camino @map("En camino")
}

model HistorialStock {
  id             Int      @id @default(autoincrement())
  materialId     Int      @map("material_id")
  estadoAnterior String?  @map("estado_anterior") @db.VarChar(50)
  estadoNuevo    String   @map("estado_nuevo") @db.VarChar(50)
  usuarioId      Int      @map("usuario_id")
  observacion    String?  @db.Text
  registradoEn   DateTime @default(now()) @map("registrado_en")

  // Relaciones
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  usuario  Usuario  @relation(fields: [usuarioId], references: [id])

  @@index([materialId, registradoEn])
  @@map("historial_stock")
}

// ============================================================
// R2 — VOLUNTARIOS
// ============================================================

model Voluntario {
  id                          Int          @id @default(autoincrement())
  nombre                      String       @db.VarChar(100)
  apellido                    String       @db.VarChar(100)
  email                       String       @unique @db.VarChar(150)
  telefono                    String?      @db.VarChar(20)
  datosMedicos                String       @map("datos_medicos") @db.Text
  contactoEmergenciaNombre    String       @map("contacto_emergencia_nombre") @db.VarChar(100)
  contactoEmergenciaTelefono  String       @map("contacto_emergencia_telefono") @db.VarChar(20)
  terminosAceptados           Boolean      @default(false) @map("terminos_aceptados")
  terminosAceptadosEn         DateTime?    @map("terminos_aceptados_en")
  estado                      EstadoVoluntario @default(Pendiente)
  especialidad                Especialidad?
  experienciaAnos             Int          @default(0) @map("experiencia_anos")
  habilidades                 String?      @db.Text
  inscritoEn                  DateTime     @default(now()) @map("inscrito_en")

  @@index([especialidad])
  @@map("voluntarios")
}

enum EstadoVoluntario {
  Pendiente
  Activo
  Rechazado
}

enum Especialidad {
  fuerza_general
  tecnico
  jefe_cuadrilla
}

// ============================================================
// DONACIONES
// ============================================================

model Donacion {
  id            Int            @id @default(autoincrement())
  donanteNombre String?        @map("donante_nombre") @db.VarChar(150)
  donanteEmail  String?        @map("donante_email") @db.VarChar(150)
  monto         Decimal        @db.Decimal(12, 2)
  metodoPago    MetodoPago?    @map("metodo_pago")
  estado        EstadoDonacion @default(pendiente)
  usuarioId     Int?           @map("usuario_id")
  creadoEn      DateTime       @default(now()) @map("creado_en")

  // Relaciones
  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([creadoEn])
  @@map("donaciones")
}

enum EstadoDonacion {
  pendiente
  confirmada
  rechazada
}

enum MetodoPago {
  transferencia
  tarjeta
  efectivo
}
